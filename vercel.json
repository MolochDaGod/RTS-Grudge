{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://grudge-warlords-rpg-production-757f.up.railway.app/api/$1"
    },
    {
      "src": "/auth/(.*)",
      "dest": "https://id.grudge-studio.com/auth/$1"
    },
    {
      "src": "/Models/(.*)",
      "dest": "https://assets.grudge-studio.com/models/$1"
    },
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)\\.(?:glb|gltf|png|jpg|webp|mp3|wav|ogg|wasm)$",
      "headers": { "Cache-Control": "public, max-age=86400" },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
