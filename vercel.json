{
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/public",
  "installCommand": "npm ci --ignore-scripts",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/game/:path*",
      "destination": "https://api.grudge-studio.com/:path*"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "https://id.grudge-studio.com/api/auth/:path*"
    },
    {
      "source": "/api/assets/:path*",
      "destination": "https://assets.grudge-studio.com/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "${RAILWAY_PUBLIC_URL}/api/:path*"
    },
    {
      "source": "/((?!api|assets|models|Models|data|sounds|textures|icons|_next).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:glb|gltf|fbx|bin|hdr|exr))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/data/grudge/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    }
  ]
}
