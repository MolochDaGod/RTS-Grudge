{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://api.grudge-studio.com/api/$1"
    },
    {
      "src": "/auth/(.*)",
      "dest": "https://id.grudge-studio.com/auth/$1"
    },
    {
      "src": "/models/(.*\\.(?:glb|gltf|fbx|bin))$",
      "dest": "https://assets.grudge-studio.com/models/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400",
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/Models/(.*)",
      "dest": "https://assets.grudge-studio.com/models/$1"
    },
    {
      "src": "/textures/(.*)\\.(?:png|jpg|webp)$",
      "dest": "https://assets.grudge-studio.com/textures/$1",
      "headers": {
        "Cache-Control": "public, max-age=86400",
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)\\.(?:glb|gltf|fbx|FBX|png|jpg|webp|mp3|wav|ogg|wasm)$",
      "headers": {
        "Cache-Control": "public, max-age=86400",
        "Access-Control-Allow-Origin": "*"
      },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self' https://id.grudge-studio.com https://*.grudge-studio.com; frame-src 'self' https://forge.grudge-studio.com https://*.grudge-studio.com" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
