# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database (MySQL — Grudge backend) ─────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=grudge_admin
MYSQL_PASSWORD=
MYSQL_DATABASE=grudge_game

# ── Grudge ID Service ─────────────────────────────────────────────────────────
GRUDGE_ID_URL=https://id.grudge-studio.com

# ── CORS (comma-separated origins allowed in production) ──────────────────────
# CORS_ORIGINS=https://grudgewarlords.com,https://client.grudge-studio.com

# ── Grudge Admin ──────────────────────────────────────────────────────────────
# Token required for admin-only endpoints (POST /api/grudge/assets, /api/grudge/sync).
# In development mode this check is bypassed.
# GRUDGE_ADMIN_TOKEN=your-secret-admin-token

# ── R2 / Cloudflare (optional — enables asset CDN uploads) ───────────────────
# CLOUDFLARE_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_GAMEDATA_BUCKET=grudge-gamedata
# R2_BUCKET_NAME=grudge-assets
# R2_CDN_BASE=https://assets.grudge-studio.com

# ── AI Providers (all optional — at least one needed for /api/ai-chat) ────────
# OPENROUTER_API_KEY=sk-or-v1-...
# MEGALLM_API_KEY=sk-mega-...
# AGENTROUTER_API_KEY=sk-...
# ROUTEWAY_API_KEY=sk-...

# ── Meshy AI 3D Pipeline (optional) ──────────────────────────────────────────
# MESHY_API_KEY=msy_...

# ── Crossmint Wallet Provisioning (optional) ─────────────────────────────────
# CROSSMINT_API_KEY=sk_...
# CROSSMINT_ENV=staging          # "staging" or "production"
# CROSSMINT_BASE_URL=            # Override — auto-derived from CROSSMINT_ENV
# CROSSMINT_CHAIN=solana         # Default: solana

# ── Railway (Survival API deployment) ──────────────────────────────────────────
# SURVIVAL_RAILWAY_PROJECT_ID=f56dde56-8747-4e68-81a2-d761bd2f0d6e
# SURVIVAL_RAILWAY_TOKEN=        # Railway API token for deploy/manage
