# ─────────────────────────────────────────────────────────────────────────────
# RTS-Grudge / Grudge Warlords — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to .env for local development.
# Set these in Railway dashboard for production (never commit real secrets).

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (Railway MySQL — do NOT use Neon for new services) ──────────────
# Replace Neon Postgres references with Railway MySQL.
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/grudge

# ── Grudge Auth (id.grudge-studio.com) ───────────────────────────────────────
GRUDGE_AUTH_SECRET=REPLACE_WITH_JWT_SECRET
GRUDGE_ID_BASE=https://id.grudge-studio.com
AUTH_ORIGIN=https://id.grudge-studio.com

# ── Object Storage (Cloudflare R2 / GitHub Pages mirror) ─────────────────────
OBJECTSTORE_WORKER_URL=https://assets.grudge-studio.com

# ── Client / Vite (prefix with VITE_ to expose to browser) ──────────────────
VITE_API_BASE=http://localhost:3001
VITE_GRUDGE_AUTH_URL=https://id.grudge-studio.com
VITE_OBJECTSTORE_BASE=https://molochdagod.github.io/ObjectStore
VITE_OBJECTSTORE_WORKER_URL=https://assets.grudge-studio.com

# ── Grudge Admin ──────────────────────────────────────────────────────────────
# Token required for admin-only endpoints (POST /api/grudge/assets, /api/grudge/sync).
# In development mode this check is bypassed.
# GRUDGE_ADMIN_TOKEN=your-secret-admin-token

# ── Discord OAuth (optional — for Discord login) ─────────────────────────────
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=https://grudgewarlords.com/auth/discord/callback

# ── Web3Auth / Solana (optional) ─────────────────────────────────────────────
# WEB3AUTH_CLIENT_ID=

# ── AI Providers (all optional — at least one needed for /api/ai-chat) ────────
# OPENROUTER_API_KEY=sk-or-v1-...
# MEGALLM_API_KEY=sk-mega-...

# ── Meshy AI 3D Pipeline (optional) ──────────────────────────────────────────
# MESHY_API_KEY=msy_...

# ── Crossmint Wallet Provisioning (optional) ─────────────────────────────────
# CROSSMINT_API_KEY=sk_...
# CROSSMINT_ENV=staging
# CROSSMINT_CHAIN=solana
