# RTS-Grudge environment variables
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# Convention:
#   VITE_  prefix → bundled into the client (public, visible to browser)
#   No prefix     → server-only, never sent to client

# ═══════════════════════════════════════════════════════════════════
# 1. Grudge Studio identity + API (required for auth)
# ═══════════════════════════════════════════════════════════════════
# Central REST API (catalog, entitlements, saves).
VITE_GRUDGE_API_URL=https://api.grudge-studio.com
GRUDGE_API_URL=https://api.grudge-studio.com

# Identity service (login redirect, /api/auth/me, SSO exchange).
VITE_GRUDGE_AUTH_URL=https://id.grudge-studio.com
GRUDGE_AUTH_URL=https://id.grudge-studio.com

# Redirect target after login (defaults to VITE_GRUDGE_AUTH_URL/login).
# VITE_GRUDGE_LOGIN_URL=https://id.grudge-studio.com/login

# ═══════════════════════════════════════════════════════════════════
# 2. JWT verification (pick ONE of the three options below)
# ═══════════════════════════════════════════════════════════════════
# Option A — RS256 via JWKS (recommended once id.grudge-studio.com exposes it)
# GRUDGE_JWKS_URL=https://id.grudge-studio.com/.well-known/jwks.json
# GRUDGE_JWT_ISSUER=https://id.grudge-studio.com   # optional iss claim check
# GRUDGE_JWT_AUDIENCE=rts-grudge                   # optional aud claim check

# Option B — HS256 shared secret (current Grudge Studio default)
# GRUDGE_JWT_SECRET=<copy the value of JWT_SECRET from The-ENGINE Railway>

# Option C — no local secret; server verifies by calling /api/auth/me per
# socket connection (slow path; works without any secret configured).

# Enable debug logging for auth failures (set to 1 during initial setup only).
GRUDGE_AUTH_DEBUG=0

# ═══════════════════════════════════════════════════════════════════
# 3. Real-time servers (PvP + World)
# ═══════════════════════════════════════════════════════════════════
# Client-facing socket URL. Empty = same origin as the SPA (default for Railway).
VITE_GRUDGE_PVP_URL=
VITE_GRUDGE_WORLD_URL=

# Allow unauthenticated socket connections (dev only — NEVER set to 1 in prod).
GRUDGE_PVP_ALLOW_GUESTS=0

# ═══════════════════════════════════════════════════════════════════
# 4. Database
# ═══════════════════════════════════════════════════════════════════
# Game-save + loadout Postgres (Railway free Postgres for this service).
# DATABASE_URL=postgresql://...

# Grudge Studio asset-registry Postgres (the central DB — read-only from here).
# GRUDGE_DATABASE_URL=postgresql://...

# ═══════════════════════════════════════════════════════════════════
# 5. Optional integrations
# ═══════════════════════════════════════════════════════════════════
# MESHY_API_KEY=           # 3-D asset generation pipeline
# CROSSMINT_API_KEY=       # Solana wallet provisioning (Crossmint custodial)
# OPENROUTER_API_KEY=      # AI chat (VIBE engine) — falls back to embedded key
# GRUDGE_ADMIN_TOKEN=      # Static bearer token for the /api/admin/* routes
