# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Database (Neon Postgres) ──────────────────────────────────────────────────
# Primary connection string — used by saves, loadouts, wallets.
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Grudge-specific DB (asset registry, weapons, skills, armor, consumables).
# Falls back to DATABASE_URL when both are needed.
# GRUDGE_DATABASE_URL=postgresql://user:pass@host/grudge?sslmode=require

# ── Grudge Admin ──────────────────────────────────────────────────────────────
# Token required for admin-only endpoints (POST /api/grudge/assets, /api/grudge/sync).
# In development mode this check is bypassed.
# GRUDGE_ADMIN_TOKEN=your-secret-admin-token

# ── AI Providers (all optional — at least one needed for /api/ai-chat) ────────
# OPENROUTER_API_KEY=sk-or-v1-...
# MEGALLM_API_KEY=sk-mega-...
# AGENTROUTER_API_KEY=sk-...
# ROUTEWAY_API_KEY=sk-...

# ── Meshy AI 3D Pipeline (optional) ──────────────────────────────────────────
# MESHY_API_KEY=msy_...

# ── Crossmint Wallet Provisioning (optional) ─────────────────────────────────
# CROSSMINT_API_KEY=sk_...
# CROSSMINT_ENV=staging          # "staging" or "production"
# CROSSMINT_BASE_URL=            # Override — auto-derived from CROSSMINT_ENV
# CROSSMINT_CHAIN=solana         # Default: solana
